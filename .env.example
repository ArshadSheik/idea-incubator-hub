# ─── Required ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ─── Flask runtime ────────────────────────────────────────────────────────────
FLASK_APP=run.py
# Options: development | testing | production  (default: development)
FLASK_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Defaults to sqlite:///app.db (project root) if not set.
# Override for a different location or engine, e.g.:
#   DATABASE_URL=sqlite:////absolute/path/to/app.db
#   DATABASE_URL=postgresql://user:pass@localhost/idea_incubator
DATABASE_URL=sqlite:///app.db

# ─── Email (optional — only needed for password-reset / notification emails) ─
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password
# Defaults to MAIL_USERNAME if not set
# MAIL_DEFAULT_SENDER=Idea Incubator <your-gmail-address@gmail.com>

# ─── AI Chatbot / Idea Insights (optional) ───────────────────────────────────
# Set AI_PROVIDER to "groq" (free, default), "deepseek", or "openai".
# Groq — free tier, no credit card required (recommended):
# AI_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# DeepSeek — very cheap pay-per-use:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# OpenAI — pay-per-use:
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# ─── Google OAuth (optional — only needed for "Sign in with Google") ─────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
